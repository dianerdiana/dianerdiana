---
import { getCollection } from "astro:content";
import { themeConfig } from "../configs/theme-config";

const articles = (await getCollection("articles"))
  .sort((current, next) => new Date(next.data.publishedAt).getTime() - new Date(current.data.publishedAt).getTime())
  .slice(0, 3);
const section = themeConfig.sections.articles;
---

<section id="articles" class="border-y border-border bg-surface py-24 md:py-section">
  <div class="container">
    <div class="mb-12 max-w-[760px]">
      <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">{section.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-bold leading-tight text-text-primary md:text-[36px]">{section.heading}</h2>
      <p class="mt-5 text-text-secondary">{section.description}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        articles.map(({ data: article }) => (
          <article class="rounded-card border border-border bg-surface p-6 shadow-soft">
            <p class="text-sm text-text-secondary">
              {
                new Intl.DateTimeFormat("en-US", {
                  month: "long",
                  day: "2-digit",
                  year: "numeric",
                  timeZone: "UTC",
                }).format(new Date(article.publishedAt))
              }
            </p>
            <h3 class="mt-3 text-[22px] font-semibold leading-tight text-text-primary">{article.title}</h3>
            <p class="mt-3 text-sm leading-6 text-text-secondary">{article.description}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-8">
      <a class="text-sm font-semibold text-primary no-underline hover:text-hover" href={section.cta.href}>{section.cta.label}</a>
    </div>
  </div>
</section>
