---
interface ArticleData {
  title: string;
  description: string;
  publishedAt: Date | string;
  readTimeMinutes: number;
  views: number;
  topics: string[];
  image: string;
  imageAlt: string;
}

interface Props {
  article: {
    id: string;
    data: ArticleData;
  };
  initialHidden?: boolean;
}

const { article, initialHidden = false } = Astro.props;
const publishedAt = new Date(article.data.publishedAt);
const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "2-digit",
  year: "numeric",
  timeZone: "UTC",
}).format(publishedAt);
const formattedViews = new Intl.NumberFormat("en-US").format(article.data.views);
const topics = article.data.topics;
---

<article
  class="group overflow-hidden rounded-card border border-border bg-surface shadow-soft transition duration-200 ease-out hover:-translate-y-1 hover:border-primary/50"
  data-article-card
  data-title={article.data.title}
  data-date={publishedAt.toISOString()}
  data-read-time={article.data.readTimeMinutes}
  data-views={article.data.views}
  data-topics={topics.join(",")}
  hidden={initialHidden}
>
  <a class="grid h-full text-text-primary no-underline md:grid-cols-[280px_minmax(0,1fr)]" href={`/blog/${article.id}`}>
    <div class="min-h-56 border-b border-border bg-background md:min-h-full md:border-b-0 md:border-r">
      <img
        class="h-full w-full object-cover"
        src={article.data.image}
        alt={article.data.imageAlt}
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="flex min-h-full flex-col p-6">
      <time class="text-sm font-medium text-text-secondary" datetime={publishedAt.toISOString()}>{formattedDate}</time>
      <h2 class="mt-3 text-[22px] font-semibold leading-tight text-text-primary transition duration-200 ease-out group-hover:text-primary">
        {article.data.title}
      </h2>
      <p class="mt-3 text-sm leading-6 text-text-secondary">{article.data.description}</p>

      <div class="mt-8 flex flex-col gap-4 border-t border-border pt-5 sm:flex-row sm:items-end sm:justify-between">
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-medium text-text-secondary">
          <span class="inline-flex items-center gap-2">
            <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 6v6l4 2"></path>
            </svg>
            {article.data.readTimeMinutes} min read
          </span>
          <span class="inline-flex items-center gap-2">
            <svg class="h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            {formattedViews} views
          </span>
        </div>

        <div class="flex flex-wrap justify-start gap-2 sm:justify-end" aria-label="Article topics">
          {
            topics.map((topic) => (
              <span class="rounded-md border border-border bg-background px-2 py-1 text-xs font-semibold text-text-secondary">
                {topic}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </a>
</article>
