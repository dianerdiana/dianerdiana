---
import { getCollection } from "astro:content";
import { themeConfig } from "../configs/theme-config";

const certificates = (await getCollection("certificates")).sort((current, next) => current.data.order - next.data.order);
const section = themeConfig.sections.certificates;
---

<section id="certificates" class="py-24 md:py-section">
  <div class="container">
    <div class="mb-12 max-w-[760px]">
      <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">{section.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-bold leading-tight text-text-primary md:text-[36px]">{section.heading}</h2>
      <p class="mt-5 text-text-secondary">
        {section.description}
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        certificates.map(({ data: certificate }) => (
          <article class="rounded-card border border-border bg-surface p-6 shadow-soft">
            <div class="mb-5 h-28 rounded-lg border border-border bg-background" aria-hidden="true" />
            <h3 class="text-[22px] font-semibold leading-tight text-text-primary">{certificate.title}</h3>
            <p class="mt-2 text-sm text-text-secondary">{certificate.issuer}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
