---
import BaseLayout from "../layouts/base-layout.astro";

interface SummaryItem {
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  heading: string;
  intro: string;
  backHref: string;
  backLabel: string;
  items: SummaryItem[];
}

const { title, description, eyebrow, heading, intro, backHref, backLabel, items } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="pt-32 pb-24 md:pt-40 md:pb-section">
    <div class="container">
      <a class="text-sm font-semibold text-text-secondary no-underline hover:text-primary" href={backHref}>
        {backLabel}
      </a>

      <div class="mt-8 max-w-content">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">{eyebrow}</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-text-primary md:text-[56px] md:leading-[1.1]">
          {heading}
        </h1>
        <p class="mt-6 text-[17px] leading-[1.7] text-text-secondary">{intro}</p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2">
        {
          items.map((item) => (
            <article class="rounded-card border border-border bg-surface p-6 shadow-soft">
              <h2 class="text-[22px] font-semibold leading-tight text-text-primary">{item.title}</h2>
              <p class="mt-3 text-sm leading-6 text-text-secondary">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
