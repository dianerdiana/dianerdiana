---
interface ProjectCardData {
  title: string;
  summary: string;
  problem: string;
  solution: string;
  result: string;
  technologies: string[];
  categories: string[];
  role: string;
  year: string;
}

interface Props {
  project: ProjectCardData;
  categoryLabels?: string[];
  filterGroup?: string;
}

const { project, categoryLabels = [], filterGroup } = Astro.props;
const categoryValues = project.categories.join(" ");
---

<article
  class="group rounded-card border border-border bg-surface p-5 shadow-soft transition duration-200 ease-out hover:-translate-y-1 hover:border-primary/50 md:p-6"
  data-tab-target={filterGroup}
  data-categories={categoryValues}
>
  <div class="flex min-h-full flex-col">
    <div class="rounded-lg border border-border bg-background p-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap gap-2">
          {
            categoryLabels.map((category) => (
              <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">{category}</span>
            ))
          }
        </div>
        <span class="text-xs font-semibold uppercase tracking-[0.12em] text-text-secondary">{project.year}</span>
      </div>

      <div class="mt-8 grid h-24 grid-cols-5 grid-rows-2 gap-2" aria-hidden="true">
        <div class="col-span-2 rounded-md bg-primary/15 transition duration-200 ease-out group-hover:bg-primary/25"></div>
        <div class="rounded-md bg-accent/20 transition duration-200 ease-out group-hover:bg-accent/30"></div>
        <div class="col-span-2 rounded-md bg-text-secondary/15 transition duration-200 ease-out group-hover:bg-text-secondary/25"></div>
        <div class="rounded-md bg-text-secondary/15 transition duration-200 ease-out group-hover:bg-text-secondary/25"></div>
        <div class="col-span-3 rounded-md bg-primary/10 transition duration-200 ease-out group-hover:bg-primary/20"></div>
        <div class="rounded-md bg-accent/15 transition duration-200 ease-out group-hover:bg-accent/25"></div>
      </div>
    </div>

    <div class="mt-5 flex flex-1 flex-col">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-text-secondary">
        <span>{project.role}</span>
        <span aria-hidden="true">/</span>
        <span>{project.technologies.length} tools</span>
      </div>

      <h3 class="mt-3 text-[22px] font-semibold leading-tight text-text-primary">{project.title}</h3>
      <p class="mt-3 text-sm leading-6 text-text-secondary">{project.summary}</p>

      <dl class="mt-6 grid gap-4 border-t border-border pt-5 md:grid-cols-3">
        <div>
          <dt class="text-sm font-semibold text-text-primary">Problem</dt>
          <dd class="mt-2 text-sm leading-6 text-text-secondary">{project.problem}</dd>
        </div>
        <div>
          <dt class="text-sm font-semibold text-text-primary">Solution</dt>
          <dd class="mt-2 text-sm leading-6 text-text-secondary">{project.solution}</dd>
        </div>
        <div>
          <dt class="text-sm font-semibold text-text-primary">Result</dt>
          <dd class="mt-2 text-sm leading-6 text-text-secondary">{project.result}</dd>
        </div>
      </dl>

      <div class="mt-6 flex flex-wrap gap-2">
        {
          project.technologies.map((technology) => (
            <span class="rounded-full border border-border bg-background px-3 py-1 text-xs font-medium text-text-secondary">
              {technology}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</article>
