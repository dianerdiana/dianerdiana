---
import { themeConfig } from "../configs/theme-config";

const about = themeConfig.sections.about;
---

<section id="about" class="border-y border-border bg-surface py-24 md:py-section">
  <div class="container grid gap-10 lg:grid-cols-[360px_minmax(0,1fr)]">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">{about.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-bold leading-tight text-text-primary md:text-[36px]">
        {about.heading}
      </h2>
    </div>

    <div class="content-width">
      {
        about.paragraphs.map((paragraph, index) => (
          <p class:list={[index > 0 && "mt-5", "text-text-secondary"]}>{paragraph}</p>
        ))
      }
    </div>
  </div>
</section>
