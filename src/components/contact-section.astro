---
import { themeConfig } from "../configs/theme-config";

const contactLinks = themeConfig.socialLinks;
---

<section id="contact" class="border-t border-border bg-surface py-24 md:py-section">
  <div class="container grid gap-10 lg:grid-cols-[minmax(0,760px)_minmax(280px,1fr)] lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">{themeConfig.sections.contact.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-bold leading-tight text-text-primary md:text-[36px]">
        {themeConfig.sections.contact.heading}
      </h2>
      <p class="mt-5 text-text-secondary">
        {themeConfig.sections.contact.description}
      </p>
    </div>

    <div class="grid gap-4">
      <div class="rounded-card border border-border bg-background p-6">
        <div class="grid gap-3">
          {
            contactLinks.map((link) => (
              <a
                class="flex items-center justify-between rounded-md border border-border bg-surface px-4 py-3 text-sm font-semibold text-text-primary no-underline transition duration-200 ease-out hover:border-primary hover:text-primary"
                href={link.href}
              >
                <span>{link.label}</span>
                <span aria-hidden="true">&rarr;</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
