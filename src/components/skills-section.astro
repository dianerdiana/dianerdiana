---
const skillGroups = [
  {
    title: "Frontend",
    items: ["Astro", "React", "TypeScript", "TailwindCSS"],
  },
  {
    title: "Backend",
    items: ["API design", "Authentication", "Validation", "Service structure"],
  },
  {
    title: "Database",
    items: ["Relational data", "Schema design", "Query planning", "Migrations"],
  },
  {
    title: "Cloud",
    items: ["Deployment", "Environment config", "Static delivery", "Runtime basics"],
  },
  {
    title: "DevOps",
    items: ["Build checks", "Version control", "Release discipline", "Debugging"],
  },
  {
    title: "Tools",
    items: ["Git", "Node.js", "npm", "Documentation"],
  },
];
---

<section id="skills" class="py-24 md:py-section">
  <div class="container">
    <div class="mb-12 max-w-[760px]">
      <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">Skills</p>
      <h2 class="mt-4 text-3xl font-bold leading-tight text-text-primary md:text-[36px]">A practical, maintainable stack.</h2>
      <p class="mt-5 text-text-secondary">
        Skill ditata berdasarkan kategori kerja agar mudah dipindai oleh recruiter dan tetap siap diperluas dengan data
        yang lebih spesifik pada tahap berikutnya.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        skillGroups.map((group) => (
          <article class="rounded-card border border-border bg-surface p-6 shadow-soft transition duration-200 ease-out hover:scale-[1.02]">
            <h3 class="text-[22px] font-semibold leading-tight text-text-primary">{group.title}</h3>
            <ul class="mt-5 grid gap-3">
              {group.items.map((item) => (
                <li class="flex items-center gap-3 text-sm text-text-secondary">
                  <span class="h-2 w-2 rounded-full bg-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
