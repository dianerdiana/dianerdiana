---
import { themeConfig } from "../configs/theme-config";

const skills = themeConfig.sections.skills;
const skillGroups = skills.groups;
---

<section id="skills" class="py-24 md:py-section">
  <div class="container">
    <div class="mb-12 max-w-[760px]">
      <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">{skills.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-bold leading-tight text-text-primary md:text-[36px]">{skills.heading}</h2>
      <p class="mt-5 text-text-secondary">
        {skills.description}
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        skillGroups.map((group) => (
          <article class="rounded-card border border-border bg-surface p-6 shadow-soft transition duration-200 ease-out hover:scale-[1.02]">
            <h3 class="text-[22px] font-semibold leading-tight text-text-primary">{group.title}</h3>
            <ul class="mt-5 grid gap-3">
              {group.items.map((item) => (
                <li class="flex items-center gap-3 text-sm text-text-secondary">
                  <span class="h-2 w-2 rounded-full bg-accent" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
