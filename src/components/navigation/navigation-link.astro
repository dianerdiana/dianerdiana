---
import type { NavigationLink as NavigationLinkType } from "../../types/navigation";

interface Props {
  item: NavigationLinkType;
  variant?: "desktop" | "mega" | "mobile" | "footer";
  showDescription?: boolean;
}

const { item, variant = "desktop", showDescription = false } = Astro.props;
const initials = item.label
  .split(" ")
  .map((part) => part[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
const externalAttributes = item.external ? { target: "_blank", rel: "noreferrer" } : {};

const variantClasses = {
  desktop:
    "rounded-md px-3 py-2 text-sm font-medium text-text-secondary no-underline transition duration-200 ease-out hover:bg-surface hover:text-text-primary",
  mega:
    "group flex gap-3 rounded-md border border-transparent p-3 text-text-primary no-underline transition duration-200 ease-out hover:border-border hover:bg-background hover:text-primary",
  mobile:
    "flex items-start gap-3 rounded-md border border-border bg-background p-3 text-text-primary no-underline transition duration-200 ease-out hover:border-primary hover:text-primary",
  footer: "text-sm font-medium text-text-secondary no-underline hover:text-primary",
};
---

{
  item.disabled ? (
    <span class={variantClasses[variant]} aria-disabled="true">
      {item.label}
    </span>
  ) : (
    <a class={variantClasses[variant]} href={item.href} {...externalAttributes}>
      {(variant === "mega" || variant === "mobile") && (
        <span
          class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-border bg-surface text-[11px] font-bold text-primary"
          data-navigation-icon={item.icon}
          aria-hidden="true"
        >
          {initials}
        </span>
      )}
      <span class={variant === "footer" || variant === "desktop" ? "" : "min-w-0"}>
        <span class="block text-sm font-semibold leading-5">{item.label}</span>
        {showDescription && item.description && (
          <span class="mt-1 block text-sm font-normal leading-6 text-text-secondary group-hover:text-text-secondary">
            {item.description}
          </span>
        )}
      </span>
    </a>
  )
}
