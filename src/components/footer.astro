---
import NavigationLink from "./navigation/navigation-link.astro";
import { themeConfig } from "../configs/theme-config";
import { getFooterNavigation } from "../lib/navigation";

const internalLinks = getFooterNavigation();
const profileLinks = themeConfig.socialLinks;
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface">
  <div class="container grid gap-8 py-10 md:grid-cols-[minmax(0,1fr)_auto_auto] md:items-start">
    <div>
      <p class="text-sm font-semibold text-text-primary">{themeConfig.site.name}</p>
      <p class="mt-1 text-sm text-text-secondary">{themeConfig.site.tagline}</p>
      <p class="mt-4 text-sm text-text-secondary">&copy; {year}</p>
    </div>

    <nav class="flex max-w-[520px] flex-wrap gap-x-5 gap-y-2" aria-label="Footer navigation">
      {
        internalLinks.map((link) => (
          <NavigationLink item={link} variant="footer" />
        ))
      }
    </nav>

    <div class="flex flex-wrap gap-x-5 gap-y-2 md:justify-end">
      {
        profileLinks.map((link) => (
          <a class="text-sm font-medium text-text-secondary no-underline hover:text-primary" href={link.href}>
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
