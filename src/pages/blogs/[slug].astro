---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/base-layout.astro";
import { themeConfig } from "../../configs/theme-config";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const publishedAt = new Date(article.data.publishedAt);
const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "2-digit",
  year: "numeric",
  timeZone: "UTC",
}).format(publishedAt);
const formattedViews = new Intl.NumberFormat("en-US").format(article.data.views);
---

<BaseLayout title={article.data.title} description={article.data.description} image={article.data.image}>
  <article class="pt-32 pb-24 md:pt-40 md:pb-section">
    <div class="container">
      <a class="text-sm font-semibold text-text-secondary no-underline hover:text-primary" href={themeConfig.pages.articleDetail.backHref}>
        {themeConfig.pages.articleDetail.backLabel}
      </a>

      <header class="mt-8 max-w-content">
        <div class="flex flex-wrap gap-2">
          {
            article.data.topics.map((topic) => (
              <span class="rounded-md border border-border bg-surface px-2 py-1 text-xs font-semibold text-text-secondary">
                {topic}
              </span>
            ))
          }
        </div>

        <h1 class="mt-5 text-4xl font-bold leading-tight text-text-primary md:text-[56px] md:leading-[1.1]">
          {article.data.title}
        </h1>
        <p class="mt-6 text-[17px] leading-[1.7] text-text-secondary">{article.data.description}</p>

        <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-medium text-text-secondary">
          <time datetime={publishedAt.toISOString()}>{formattedDate}</time>
          <span aria-hidden="true">/</span>
          <span>{article.data.readTimeMinutes} min read</span>
          <span aria-hidden="true">/</span>
          <span>{formattedViews} views</span>
        </div>
      </header>

      <div class="mt-10 overflow-hidden rounded-card border border-border bg-surface shadow-soft">
        <img class="h-auto w-full object-cover" src={article.data.image} alt={article.data.imageAlt} loading="eager" />
      </div>

      <div class="article-content mt-12 max-w-content">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-content {
    color: var(--color-text-primary);
    font-size: 17px;
    line-height: 1.8;
  }

  .article-content :global(p) {
    margin-block: 0 24px;
    color: var(--color-text-secondary);
  }

  .article-content :global(h2) {
    margin-block: 40px 16px;
    color: var(--color-text-primary);
    font-size: 28px;
    font-weight: 700;
    line-height: 1.25;
  }

  .article-content :global(h3) {
    margin-block: 32px 12px;
    color: var(--color-text-primary);
    font-size: 22px;
    font-weight: 650;
    line-height: 1.3;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-block: 0 24px;
    padding-left: 24px;
    color: var(--color-text-secondary);
  }

  .article-content :global(li + li) {
    margin-top: 8px;
  }

  .article-content :global(a) {
    font-weight: 600;
  }
</style>
