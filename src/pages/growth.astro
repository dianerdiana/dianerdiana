---
import BaseLayout from "../layouts/base-layout.astro";
import NavigationLink from "../components/navigation/navigation-link.astro";
import { getNavigationMenu } from "../lib/navigation";

const growthMenu = getNavigationMenu("growth");

if (!growthMenu) {
  throw new Error("Growth navigation menu is missing.");
}
---

<BaseLayout
  title="Growth"
  description="A calm archive of achievements, books, running, learning, certifications, and languages."
>
  <section class="pt-32 pb-24 md:pt-40 md:pb-section">
    <div class="container">
      <div class="max-w-content">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">Growth</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-text-primary md:text-[56px] md:leading-[1.1]">
          Progress, practice, and learning beyond project work.
        </h1>
        <p class="mt-6 text-[17px] leading-[1.7] text-text-secondary">
          This space collects the habits and milestones that support durable engineering growth: what I learn, what I practice, and what I keep refining over time.
        </p>
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          growthMenu.children.map((item) => (
            <NavigationLink item={item} variant="mobile" showDescription />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
