---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout
  title="Dian Erdiana"
  description="Portfolio software engineer yang rapi, terstruktur, dan berfokus pada kualitas implementasi."
>
  <section class="section">
    <div class="container">
      <div class="content-width rounded-card border border-border bg-surface p-6 shadow-soft">
        <p class="mb-3 text-sm text-text-secondary">Foundation ready</p>
        <h1 class="text-4xl font-bold leading-tight text-text-primary md:text-[56px] md:leading-[1.1]">
          Engineering over aesthetics.
        </h1>
        <p class="mt-6 text-text-secondary">
          Fondasi Astro, TailwindCSS, React integration, dan design token global sudah siap untuk tahap berikutnya.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
