---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/base-layout.astro";
import BlogArticleCard from "../components/blog-article-card.astro";

const allArticles = (await getCollection("articles")).sort(
  (current, next) => new Date(next.data.publishedAt).getTime() - new Date(current.data.publishedAt).getTime(),
);
const topics = Array.from(new Set(allArticles.flatMap((article) => article.data.topics))).sort((current, next) =>
  current.localeCompare(next),
);
const sortOptions = [
  { label: "Newest", value: "newest" },
  { label: "Oldest", value: "oldest" },
  { label: "Most viewed", value: "most-viewed" },
  { label: "Shortest read", value: "shortest-read" },
  { label: "Longest read", value: "longest-read" },
];
---

<BaseLayout
  title="Blogs"
  description="Kumpulan artikel Dian Erdiana tentang engineering, frontend, portfolio, dan keputusan teknis."
>
  <section class="pt-32 pb-24 md:pt-40 md:pb-section" data-blog-index>
    <div class="container">
      <div class="max-w-[760px]">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-primary">Blogs</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-text-primary md:text-[56px] md:leading-[1.1]">
          Notes on engineering decisions and clear interfaces.
        </h1>
        <p class="mt-6 text-[17px] leading-[1.7] text-text-secondary">
          Artikel singkat tentang bagaimana struktur, tradeoff, dan detail interface bisa membuat software terasa lebih
          rapi dan mudah dipercaya.
        </p>
      </div>

      <div class="mt-14 grid gap-8 lg:grid-cols-[280px_minmax(0,1fr)] lg:items-start">
        <aside class="space-y-6 lg:sticky lg:top-28" aria-label="Blog filters">
          <section class="rounded-card border border-border bg-surface p-6 shadow-soft">
            <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-text-primary">Sorting</h2>
            <div class="mt-5 grid gap-2" role="group" aria-label="Sort articles">
              {
                sortOptions.map((option) => (
                  <button
                    class="rounded-md border border-border bg-background px-3 py-2 text-left text-sm font-semibold text-text-secondary transition duration-200 ease-out hover:border-primary hover:text-primary"
                    type="button"
                    data-sort-trigger
                    data-sort-value={option.value}
                    data-selected={option.value === "newest" ? "true" : "false"}
                    aria-pressed={option.value === "newest" ? "true" : "false"}
                  >
                    {option.label}
                  </button>
                ))
              }
            </div>
          </section>

          <section class="rounded-card border border-border bg-surface p-6 shadow-soft">
            <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-text-primary">Topics</h2>
            <div class="mt-5 flex flex-wrap items-baseline justify-start gap-2 text-sm" role="group" aria-label="Filter by topics">
              <button
                class="rounded-md border border-border bg-background px-2 py-1 text-xs font-semibold text-text-secondary transition duration-200 ease-out hover:border-primary hover:text-primary"
                type="button"
                data-clear-topics
                data-selected="true"
                aria-pressed="true"
              >
                All topics
              </button>
              {
                topics.map((topic) => (
                  <button
                    class="rounded-md border border-border bg-background px-2 py-1 text-xs font-semibold text-text-secondary transition duration-200 ease-out hover:border-primary hover:text-primary"
                    type="button"
                    data-topic-trigger
                    data-topic-value={topic}
                    data-selected="false"
                    aria-pressed="false"
                  >
                    {topic}
                  </button>
                ))
              }
            </div>
          </section>
        </aside>

        <div>
          <div class="mb-5 flex flex-col gap-2 border-b border-border pb-5 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="text-sm font-semibold text-text-primary">Article index</p>
              <p class="mt-1 text-sm text-text-secondary" data-result-summary>
                Showing 1-10 of {allArticles.length} articles
              </p>
            </div>
            <p class="text-sm text-text-secondary">10 articles per page</p>
          </div>

          <div class="grid gap-5" data-articles-list>
            {
              allArticles.map((article, index) => (
                <BlogArticleCard article={article} initialHidden={index >= 10} />
              ))
            }
          </div>

          <div class="mt-8 hidden rounded-card border border-border bg-surface p-6 text-sm text-text-secondary shadow-soft" data-empty-state>
            Tidak ada article yang cocok dengan topic terpilih.
          </div>

          <nav class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between" aria-label="Blog pagination">
            <p class="text-sm text-text-secondary" data-page-summary>Page 1 of 1</p>
            <div class="flex flex-wrap gap-2" data-pagination></div>
          </nav>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  [data-sort-trigger][data-selected="true"],
  [data-topic-trigger][data-selected="true"],
  [data-clear-topics][data-selected="true"] {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, var(--color-surface));
    color: var(--color-primary);
  }

  [data-page-button][data-selected="true"] {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: #ffffff;
  }
</style>

<script>
  const setupBlogIndex = () => {
    document.querySelectorAll("[data-blog-index]").forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.blogIndexReady === "true") {
        return;
      }

      root.dataset.blogIndexReady = "true";

      const pageSize = 10;
      const articles = Array.from(root.querySelectorAll("[data-article-card]")).filter(
        (article) => article instanceof HTMLElement,
      );
      const sortTriggers = Array.from(root.querySelectorAll("[data-sort-trigger]")).filter(
        (trigger) => trigger instanceof HTMLButtonElement,
      );
      const topicTriggers = Array.from(root.querySelectorAll("[data-topic-trigger]")).filter(
        (trigger) => trigger instanceof HTMLButtonElement,
      );
      const clearTopics = root.querySelector("[data-clear-topics]");
      const resultSummary = root.querySelector("[data-result-summary]");
      const pageSummary = root.querySelector("[data-page-summary]");
      const pagination = root.querySelector("[data-pagination]");
      const emptyState = root.querySelector("[data-empty-state]");
      const allowedSorts = new Set(sortTriggers.map((trigger) => trigger.dataset.sortValue));
      const allowedTopics = new Set(topicTriggers.map((trigger) => trigger.dataset.topicValue));
      const state = {
        sort: "newest",
        topics: new Set(),
        page: 1,
      };

      const parseUrl = () => {
        const params = new URLSearchParams(window.location.search);
        const sort = params.get("sort");
        const page = Number(params.get("page"));
        const topics = (params.get("topics") ?? "")
          .split(",")
          .map((topic) => topic.trim())
          .filter((topic) => allowedTopics.has(topic));

        if (sort && allowedSorts.has(sort)) {
          state.sort = sort;
        }

        state.topics = new Set(topics);
        state.page = Number.isInteger(page) && page > 0 ? page : 1;
      };

      const updateUrl = () => {
        const params = new URLSearchParams();
        if (state.sort !== "newest") {
          params.set("sort", state.sort);
        }
        if (state.topics.size > 0) {
          params.set("topics", Array.from(state.topics).sort().join(","));
        }
        if (state.page > 1) {
          params.set("page", String(state.page));
        }

        const nextUrl = params.toString() ? `${window.location.pathname}?${params.toString()}` : window.location.pathname;
        window.history.replaceState({}, "", nextUrl);
      };

      const getArticleTopics = (article) => (article.dataset.topics ?? "").split(",").filter(Boolean);
      const getSortedArticles = () => {
        return [...articles].sort((current, next) => {
          const currentDate = new Date(current.dataset.date ?? "").getTime();
          const nextDate = new Date(next.dataset.date ?? "").getTime();
          const currentViews = Number(current.dataset.views ?? 0);
          const nextViews = Number(next.dataset.views ?? 0);
          const currentReadTime = Number(current.dataset.readTime ?? 0);
          const nextReadTime = Number(next.dataset.readTime ?? 0);

          if (state.sort === "oldest") {
            return currentDate - nextDate;
          }
          if (state.sort === "most-viewed") {
            return nextViews - currentViews || nextDate - currentDate;
          }
          if (state.sort === "shortest-read") {
            return currentReadTime - nextReadTime || nextDate - currentDate;
          }
          if (state.sort === "longest-read") {
            return nextReadTime - currentReadTime || nextDate - currentDate;
          }

          return nextDate - currentDate;
        });
      };

      const getFilteredArticles = () => {
        const selectedTopics = Array.from(state.topics);
        const sortedArticles = getSortedArticles();

        if (selectedTopics.length === 0) {
          return sortedArticles;
        }

        return sortedArticles.filter((article) => {
          const articleTopics = getArticleTopics(article);
          return selectedTopics.some((topic) => articleTopics.includes(topic));
        });
      };

      const makePageButton = (label, page, options = {}) => {
        const button = document.createElement("button");
        button.type = "button";
        button.textContent = label;
        button.className =
          "min-h-10 rounded-md border border-border bg-surface px-3 py-2 text-sm font-semibold text-text-secondary transition duration-200 ease-out hover:border-primary hover:text-primary disabled:cursor-not-allowed disabled:opacity-40";
        button.dataset.pageButton = "true";
        button.dataset.selected = options.selected ? "true" : "false";
        button.disabled = Boolean(options.disabled);
        button.setAttribute("aria-label", options.ariaLabel ?? `Go to page ${page}`);
        if (options.selected) {
          button.setAttribute("aria-current", "page");
        }
        button.addEventListener("click", () => {
          state.page = page;
          applyState();
        });
        return button;
      };

      const updateControls = () => {
        sortTriggers.forEach((trigger) => {
          const isSelected = trigger.dataset.sortValue === state.sort;
          trigger.dataset.selected = String(isSelected);
          trigger.setAttribute("aria-pressed", String(isSelected));
        });

        topicTriggers.forEach((trigger) => {
          const value = trigger.dataset.topicValue ?? "";
          const isSelected = state.topics.has(value);
          trigger.dataset.selected = String(isSelected);
          trigger.setAttribute("aria-pressed", String(isSelected));
        });

        if (clearTopics instanceof HTMLButtonElement) {
          const isSelected = state.topics.size === 0;
          clearTopics.dataset.selected = String(isSelected);
          clearTopics.setAttribute("aria-pressed", String(isSelected));
        }
      };

      const applyState = () => {
        const filteredArticles = getFilteredArticles();
        const totalPages = Math.max(1, Math.ceil(filteredArticles.length / pageSize));
        state.page = Math.min(Math.max(state.page, 1), totalPages);

        articles.forEach((article) => {
          article.hidden = true;
        });

        const start = (state.page - 1) * pageSize;
        const end = start + pageSize;
        const visibleArticles = filteredArticles.slice(start, end);

        visibleArticles.forEach((article) => {
          article.hidden = false;
          article.parentElement?.append(article);
        });

        if (resultSummary) {
          const from = filteredArticles.length === 0 ? 0 : start + 1;
          const to = Math.min(end, filteredArticles.length);
          resultSummary.textContent = `Showing ${from}-${to} of ${filteredArticles.length} articles`;
        }

        if (pageSummary) {
          pageSummary.textContent = `Page ${state.page} of ${totalPages}`;
        }

        if (emptyState instanceof HTMLElement) {
          emptyState.hidden = filteredArticles.length > 0;
          emptyState.classList.toggle("hidden", filteredArticles.length > 0);
        }

        if (pagination) {
          pagination.textContent = "";
          pagination.append(makePageButton("Previous", Math.max(1, state.page - 1), {
            disabled: state.page === 1,
            ariaLabel: "Go to previous page",
          }));

          for (let page = 1; page <= totalPages; page += 1) {
            pagination.append(makePageButton(String(page), page, { selected: page === state.page }));
          }

          pagination.append(makePageButton("Next", Math.min(totalPages, state.page + 1), {
            disabled: state.page === totalPages,
            ariaLabel: "Go to next page",
          }));
        }

        updateControls();
        updateUrl();
      };

      sortTriggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          state.sort = trigger.dataset.sortValue ?? "newest";
          state.page = 1;
          applyState();
        });
      });

      topicTriggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const value = trigger.dataset.topicValue ?? "";
          if (state.topics.has(value)) {
            state.topics.delete(value);
          } else {
            state.topics.add(value);
          }
          state.page = 1;
          applyState();
        });
      });

      if (clearTopics instanceof HTMLButtonElement) {
        clearTopics.addEventListener("click", () => {
          state.topics.clear();
          state.page = 1;
          applyState();
        });
      }

      parseUrl();
      applyState();
    });
  };

  setupBlogIndex();
  document.addEventListener("astro:page-load", setupBlogIndex);
</script>
