---
import "../styles/global.css";
import Footer from "../components/footer.astro";
import Navbar from "../components/navbar.astro";
import { themeConfig } from "../configs/theme-config";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = themeConfig.site.title,
  description = themeConfig.site.description,
  image = themeConfig.assets.defaultOgImage,
} = Astro.props;

const canonicalUrl = Astro.url.href;
const pageTitle = title === themeConfig.site.title ? title : `${title} | ${themeConfig.site.title}`;
---

<!doctype html>
<html lang={themeConfig.site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/x-icon" href={themeConfig.assets.favicon} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {image && <meta property="og:image" content={new URL(image, Astro.url).href} />}

    <script is:inline>
      try {
        const savedTheme = localStorage.getItem("theme");
        document.documentElement.classList.toggle("dark", savedTheme === "dark");
      } catch {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body class="bg-background text-text-primary">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
